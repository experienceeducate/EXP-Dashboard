# ── Copy to backend/.env and fill in. backend/.env is gitignored. ──
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"

# BigQuery
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account.json
BQ_PROJECT_ID=educate-data-warehouse-test
BQ_DATASET=gold_exp
BQ_TABLE=exp_ai_dashboard_model

# Auth (REQUIRED — app fails to boot without these)
JWT_SECRET=change-me-generate-a-64-hex-secret
# Shared password for the hidden fallback login path (still required to boot).
DASHBOARD_PASSWORD=change-me

# Google OAuth — the primary sign-in path. Create a "Web application" OAuth
# client (see README → Google OAuth setup) and register the redirect URI:
#   http://localhost:8000/api/auth/google/callback   (local)
#   https://exp-dashboard-api.<domain>/api/auth/google/callback  (prod)
# Optional locally: leave blank to use only the password fallback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_ALLOWED_DOMAIN=experienceeducate.org

# Access control (optional; falls back to core/access.py fallback if unset)
ACCESS_CONFIG_PATH=

# Client-header guard
CLIENT_HEADER_NAME=X-Exp-Client
CLIENT_HEADER_TOKEN=dashboard-v1

# URLs / CORS
FRONTEND_URL=http://localhost:3000
EXTRA_CORS_ORIGINS=

# Cache
CACHE_MAXSIZE=512
CACHE_TTL_SECONDS=300
